plotGR <- function(gr, col = "black", ...) {
if (is.null(names(gr))) {
names(gr) <- seq_along(gr)
}
plot(NA, NA, xlim = c(0, max(end(gr))), ylim = c(0.5, length(gr) + 0.5),
xlab = "Genomic Position", ylab = "Ranges", ...)
for (i in seq_along(gr)) {
rect(start(gr)[i], i - 0.4, end(gr)[i], i + 0.4, col = col, border = NA)
text((start(gr)[i] + end(gr)[i]) / 2, i, labels = names(gr)[i], pos = 3)
}
}
