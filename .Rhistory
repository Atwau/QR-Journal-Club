par(mar=c(4, 4, 4, 6), cex=1.5)
# Plot all genes
plot(x = deseq_results$log2FoldChange,
y = -log10(deseq_results$padj),
main = "Volcano Plot",
xlab = "log2 Fold Change",
ylab = "-log10(padj)",
pch = 20,
cex = 0.5)
# Highlight significant genes (Downregulated in blue, Upregulated in red)
points(x = sig_genes$log2FoldChange,
y = -log10(sig_genes$padj),
pch = 20,
col = ifelse(sig_genes$log2FoldChange > 0, "red", "blue"),
cex = 1)
# Add a legend for the highlighted genes
# Increase the right margin to make room if needed: par(mar=c(4, 4, 4, 6))
legend("topright",
legend = c("Downregulated", "Upregulated"),
pch = 20,
col = c("blue", "red"),
bty = "n",      # 'n' removes the white box/border entirely
cex = 0.6,      # Scales the legend text relative to the global cex
pt.cex = 1.2)   # Makes the legend dots slightly larger for visibility
# 1. Reset the graphics device (This is the most important step)
if(!is.null(dev.list())) dev.off()
# 2. Set clean, standard margins (Bottom, Left, Top, Right)
par(mar=c(5, 5, 4, 2), cex=1.0)
# 3. Calculate Y-axis limit with extra "headroom" (30%) for the legend
max_y <- max(-log10(deseq_results$padj), na.rm = TRUE)
# 4. Create the base plot
plot(x = deseq_results$log2FoldChange,
y = -log10(deseq_results$padj),
ylim = c(0, max_y * 1.3), # Essential: provides space at the top
main = "Volcano Plot",
xlab = "log2 Fold Change",
ylab = "-log10(padj)",
pch = 20,
col = "gray80", # Light gray for non-significant points
cex = 0.5)
# 5. Add colored points for significance
points(x = sig_genes$log2FoldChange,
y = -log10(sig_genes$padj),
pch = 20,
col = ifelse(sig_genes$log2FoldChange > 0, "red", "blue"),
cex = 0.7)
# 6. Add the legend (using bty="n" ensures no box covers the dots)
legend("topright",
legend = c("Downregulated", "Upregulated"),
pch = 20,
col = c("blue", "red"),
bty = "n",
cex = 0.8)
# 12. Volcano Plot
